<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization"><String Id="TauriLanguage">1033</String><String Id="TauriCodepage">1252</String><String Id="LaunchApp">Launch Liquid Glass Island</String><String Id="DowngradeErrorMessage">A newer version of Liquid Glass Island is already installed.</String><String Id="PathEnvVarFeature">Add the install location of the Liquid Glass Island executable to the PATH system environment variable. This allows the Liquid Glass Island executable to be called from any location.</String><String Id="InstallAppFeature">Installs Liquid Glass Island.</String></WixLocalization>